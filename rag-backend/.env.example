LLM_API_KEY=your_api_key_here
LLM_PROVIDER=gemini
# LLM_MODEL=
CHROMA_DB_DIR=./chroma_db

SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

MAX_HISTORY_TURNS=6

# ALLOWED_ORIGINS=https://yourdomain.com
CHAT_RATE_LIMIT=15/minute;150/day
UPLOAD_RATE_LIMIT=5/minute;20/day
MAX_UPLOAD_MB=25
MAX_PDF_PAGES=300

# ── Observability (optional) ─────────────────────────────────────────
# SENTRY_DSN=https://xxxx@yyy.ingest.sentry.io/zzz
# ENVIRONMENT=production
LOG_LEVEL=INFO
# LOG_FORMAT=json
LLM_TIMEOUT=60

# Optional: enables full auth-account deletion from the Settings modal.
# Server-side ONLY — never put this in the frontend.
# SUPABASE_SERVICE_ROLE_KEY=
