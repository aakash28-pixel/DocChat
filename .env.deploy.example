# Root deployment env (used by docker-compose.yml). Copy to .env and fill in.
# The backend also reads this file (env_file: .env), so it holds BOTH the
# compose vars and the backend runtime vars.

# ── Domain (no protocol) ─────────────────────────────────────────────
DOMAIN=docchat.example.com

# ── LLM ──────────────────────────────────────────────────────────────
LLM_API_KEY=your_llm_api_key
LLM_PROVIDER=gemini
LLM_TIMEOUT=60

# ── Supabase (from your Supabase project settings) ───────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Data paths (inside the container volume) ─────────────────────────
CHROMA_DB_DIR=/data/chroma
UPLOAD_DIR=/data/uploads

# ── Security / limits ────────────────────────────────────────────────
ALLOWED_ORIGINS=https://docchat.example.com
CHAT_RATE_LIMIT=15/minute;150/day
UPLOAD_RATE_LIMIT=5/minute;20/day
MAX_UPLOAD_MB=25
MAX_PDF_PAGES=300
MAX_HISTORY_TURNS=6

# ── Observability (optional) ─────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FORMAT=json
# ENVIRONMENT=production
# SENTRY_DSN=
# VITE_SENTRY_DSN=

# Optional: full account deletion (server-side only)
# SUPABASE_SERVICE_ROLE_KEY=
# Analytics (frontend build arg)
# VITE_PLAUSIBLE_DOMAIN=
